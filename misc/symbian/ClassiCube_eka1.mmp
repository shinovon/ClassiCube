TARGET		  ClassiCube.app
TARGETTYPE	  app
TARGETPATH        \system\apps\classicube
UID			 0x100039CE 0x1212A5C2


SYSTEMINCLUDE \Epoc32
SYSTEMINCLUDE \Epoc32\include
SYSTEMINCLUDE \Epoc32\include\libc

USERINCLUDE ../../src

MACRO CC_BUILD_SYMBIAN_ESTLIB

LIBRARY euser.lib
LIBRARY apgrfx.lib
LIBRARY cone.lib
LIBRARY fbscli.lib
LIBRARY ws32.lib
LIBRARY hal.lib
LIBRARY eikcore.lib
LIBRARY eikdlg.lib
LIBRARY apparc.lib
LIBRARY estlib.lib
