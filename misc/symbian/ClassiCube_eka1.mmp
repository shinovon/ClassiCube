LIBRARY estor.lib
LIBRARY bafl.lib

LIBRARY avkon.lib // s60
MACRO CC_BUILD_SYMBIAN_AVKON

//LIBRARY libgles_cm.lib // s60v2fp3
//MACRO CC_BUILD_SYMBIAN_GLES10

///MACRO CC_BUILD_TOUCH // s90

EPOCALLOWDLLDATA

SOURCEPATH .
